# OpenAI — required for ingestion + chat (production path)
# In tests, the AI SDK MockLanguageModelV1 / MockEmbeddingModelV1 are wired in
# via createApp(...) / createIngestionService(...) dependency injection;
# OPENAI_API_KEY is only consulted by the production composition root.
OPENAI_API_KEY=<your key>

# Postgres connection — matches docker-compose.yml service `postgres`
DATABASE_URL=postgresql://netea:netea@localhost:5432/netea_dev

# Test database (docker-compose.test.yml, port 5433, tmpfs)
TEST_DATABASE_URL=postgresql://netea:netea@localhost:5433/netea_test

# Cost cap per ingestion run (USD). Unset = no cap.
INGEST_MAX_COST_USD=5.00

# OpenAI model pins (verified at boot via AppConfigSchema)
OPENAI_MODEL_ENRICHMENT=gpt-4o-mini
OPENAI_MODEL_EMBEDDING=text-embedding-3-small
OPENAI_MODEL_CHAT=gpt-4o-mini

# When set to 1 the dev/test composition wires the AI SDK MockLanguageModelV1
# in place of the OpenAI provider. Acceptance tests inject mocks explicitly
# through createApp(...) so this is only used by `pnpm dev` for offline demo.
NETEA_USE_MOCK_LLM=0

# Prompt version stamped onto every enriched row (provenance, see ADR-006).
PROMPT_VERSION=v1
